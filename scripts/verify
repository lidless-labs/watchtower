#!/bin/bash
# Single verification entrypoint. AGENTS.md's Definition of Done defers to
# this file, so the gate lives in exactly one place. Runs only local checks;
# never touches live infrastructure (see scripts/smoke-live.sh warnings).
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# Backend gates (integration-marked tests self-skip when services are unreachable)
PY="${PY:-$ROOT/backend/venv/bin}"
cd "$ROOT/backend"
"$PY/ruff" check app tests
"$PY/pytest" -q

# Frontend gates
cd "$ROOT/frontend"
npm run lint
npm run test -- --run
npm run build
