# Watchtower Environment Configuration
# Copy to .env and fill in your values

# Redis
REDIS_URL=redis://localhost:6379

# Development mode (enables CORS for localhost frontends)
DEV_MODE=false

# Config file paths (optional, defaults shown)
CONFIG_PATH=../config/config.yaml
TOPOLOGY_PATH=../config/topology.yaml

# Local docker-compose InfluxDB bootstrap values.
# Password and admin token are REQUIRED (compose refuses to start without
# them, there are no built-in defaults). Generate strong values with:
#   openssl rand -hex 32
WATCHTOWER_INFLUXDB_USERNAME=admin
WATCHTOWER_INFLUXDB_PASSWORD=
WATCHTOWER_INFLUXDB_ADMIN_TOKEN=
